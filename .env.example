# EcoTrace — Environment Variables
#
# This project is fully client-side. No API keys or server secrets are required
# for a standard local development or production build.
#
# Copy this file to .env.local and fill in any values you want to override.
# Never commit .env.local or any file containing real credentials.
#
# See SECURITY.md for the full security model.

# ---------------------------------------------------------------------------
# Application URL
# Used to construct absolute URLs for Open Graph / share meta tags.
# In development this defaults to http://localhost:3000 automatically.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://your-domain.com

# ---------------------------------------------------------------------------
# Analytics (optional)
# EcoTrace supports Plausible Analytics — a privacy-first, cookie-free
# alternative to Google Analytics. No data is collected unless you set this.
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=your-domain.com

# ---------------------------------------------------------------------------
# Node environment — set automatically by Next.js, listed here for clarity.
# Valid values: development | test | production
# ---------------------------------------------------------------------------
# NODE_ENV=development
